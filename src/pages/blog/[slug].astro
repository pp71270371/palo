---
import Layout from '../../layouts/Layout.astro';

export const POSTS = [
	{
		slug: 'astro-routing-notes',
		title: 'Astro 路由与页面组织',
		description: '用最少心智成本组织 pages、动态路由与导航。',
		cover: '/covers/blog-astro-routing.svg',
		date: '2026-03-31',
		body: [
			'这是一篇示例文章页，用于展示 blog 子页面路由。',
			'你可以把内容替换成 Markdown/Content Collections（后续也可以帮你升级）。',
		],
	},
	{
		slug: 'design-system-basics',
		title: '小型站点的 Design System',
		description: '从字体、间距、卡片到按钮：如何保持一致性。',
		cover: '/covers/blog-design-system.svg',
		date: '2026-03-31',
		body: [
			'为小型站点建立轻量的设计系统，能让页面看起来更统一、更专业。',
			'建议从字体、颜色、间距、圆角、阴影开始，形成可复用的 Token。',
		],
	},
	{
		slug: 'performance-checklist',
		title: '性能检查清单（静态站）',
		description: '图片、字体、CSS 与路由：几个最常见的加速点。',
		cover: '/covers/blog-performance.svg',
		date: '2026-03-31',
		body: [
			'优先优化图片尺寸与格式，避免无谓的大图直出。',
			'其次关注字体加载与 CSS 体积，保持首屏关键路径尽量短。',
		],
	},
];

export function getStaticPaths() {
	return POSTS.map((post) => ({
		params: { slug: post.slug },
	}));
}

const { slug } = Astro.params;
const post = POSTS.find((x) => x.slug === slug);

if (!post) {
	return Astro.redirect('/blog');
}
---

<Layout title={`${post.title} | Palo Blog`} description={post.description}>
	<main class="page">
		<nav class="crumbs" aria-label="面包屑">
			<a href="/blog">← Back to Blog</a>
		</nav>

		<header class="header">
			<p class="date">{post.date}</p>
			<h1>{post.title}</h1>
			<p class="lead">{post.description}</p>
		</header>

		<div class="cover">
			<img src={post.cover} alt={`${post.title} cover`} />
		</div>

		<article class="article">
			{post.body.map((p) => (
				<p>{p}</p>
			))}
		</article>
	</main>
</Layout>

<style>
	.page {
		max-width: var(--page-max-width);
		margin: 0 auto;
		padding: 2.25rem var(--page-gutter) 5rem;
	}

	.crumbs a {
		display: inline-block;
		text-decoration: none;
		color: var(--text-strong);
		font-weight: var(--font-weight-bold);
		padding: 0.35rem 0.55rem;
		border-radius: 0.55rem;
	}
	.crumbs a:hover {
		background: rgba(17, 24, 39, 0.06);
		color: var(--link);
	}

	.date {
		margin: 1rem 0 0.35rem;
		color: var(--muted);
		font-size: 0.95rem;
	}

	.header h1 {
		margin: 0 0 0.5rem;
		letter-spacing: -0.03em;
	}

	.lead {
		margin: 0 0 1.25rem;
		color: var(--text-muted);
		line-height: 1.7;
		max-width: 75ch;
	}

	.cover {
		aspect-ratio: 8 / 5;
		overflow: hidden;
		border-radius: 0.95rem;
		border: 1px solid var(--border);
		background: var(--card-bg);
	}
	.cover img {
		width: 100%;
		height: 100%;
		display: block;
		object-fit: cover;
	}

	.article {
		margin-top: 1rem;
		background: var(--card-bg);
		border: 1px solid var(--border);
		border-radius: 0.95rem;
		padding: 1.25rem;
	}
	.article p {
		margin: 0 0 0.9rem;
		color: var(--text);
		line-height: 1.8;
	}
	.article p:last-child {
		margin-bottom: 0;
	}
</style>
