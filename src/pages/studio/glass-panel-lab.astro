---
import Layout from '../../layouts/Layout.astro';
---

<Layout
	title="Glass Panel Lab | Palo"
	description="用于测试二级菜单导航与玻璃背景叠加效果的页面。"
>
	<main class="page">
		<nav class="crumbs" aria-label="面包屑">
			<a href="/studio">← Back to Studio</a>
		</nav>

		<header class="header">
			<p class="eyebrow">Level Two Test Page</p>
			<h1>Glass Panel Lab</h1>
			<p class="lead">
				这里放了一组高对比卡片，方便你在打开移动端菜单时观察玻璃背景的透明度、模糊程度和覆盖范围。
			</p>
		</header>

		<section class="panels">
			<div class="panel">
				<h2>Soft Layer</h2>
				<p>观察半透明背景与正文的分离感。</p>
			</div>
			<div class="panel panel--accent">
				<h2>Bright Accent</h2>
				<p>观察菜单 overlay 对高对比背景的模糊压制效果。</p>
			</div>
		</section>
	</main>
</Layout>

<style>
	.page {
		max-width: var(--page-max-width);
		margin: 0 auto;
		padding: 2.5rem var(--page-gutter) 5rem;
	}

	.crumbs a {
		display: inline-block;
		text-decoration: none;
		color: var(--text-strong);
		font-weight: var(--font-weight-bold);
		padding: 0.35rem 0.55rem;
		border-radius: 0.55rem;
	}

	.crumbs a:hover {
		background: rgba(17, 24, 39, 0.06);
		color: var(--link);
	}

	.eyebrow {
		margin: 1rem 0 0.35rem;
		color: var(--muted);
	}

	.header h1 {
		margin: 0 0 0.75rem;
		letter-spacing: -0.03em;
	}

	.lead {
		margin: 0 0 1.5rem;
		color: var(--text-muted);
		line-height: 1.7;
	}

	.panels {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
		gap: 1rem;
	}

	.panel {
		background:
			linear-gradient(145deg, rgba(99, 102, 241, 0.2), rgba(15, 23, 42, 0.1)),
			var(--card-bg);
		border: 1px solid var(--border);
		border-radius: 1rem;
		padding: 1.25rem;
		min-height: 220px;
	}

	.panel--accent {
		background:
			radial-gradient(circle at top, rgba(96, 165, 250, 0.32), transparent 48%),
			linear-gradient(160deg, rgba(129, 140, 248, 0.28), rgba(15, 23, 42, 0.1)),
			var(--card-bg);
	}

	.panel h2 {
		margin: 0 0 0.5rem;
	}

	.panel p {
		margin: 0;
		color: var(--text-muted);
		line-height: 1.7;
	}
</style>
