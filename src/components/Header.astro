---
interface Props {
	brand?: string;
}

const navItems = [
	{ href: '/', label: 'Home' },
	{ href: '/about', label: 'About' },
	{ href: '/portfolio', label: 'Portfolio' },
	{ href: '/blog', label: 'Blog' },
	{ href: '/typography', label: 'Typography' },
	{ href: '/contact', label: 'Contact' },
];

const { brand = 'Palo' } = Astro.props;
const pathname = Astro.url.pathname;

const isActive = (href: string) =>
	href === '/' ? pathname === '/' : pathname === href || pathname.startsWith(`${href}/`);
---

<header class="site-header">
	<div class="inner">
		<a class="brand" href="/" aria-label={`${brand} 首页`}>
			<span class="name">{brand}</span>
		</a>

		<nav class="nav" aria-label="主导航">
			{navItems.map((item) => (
				<a
					href={item.href}
					class:list={{ active: isActive(item.href) }}
					aria-current={isActive(item.href) ? 'page' : undefined}
				>
					{item.label}
				</a>
			))}

				<button
					id="theme-toggle"
					type="button"
					class="theme-toggle"
					aria-label="切换深浅主题"
					title="Toggle theme"
				>
					<svg
						class="theme-icon theme-icon--sun"
						aria-hidden="true"
						viewBox="0 0 24 24"
					>
						<circle cx="12" cy="12" r="4" />
						<path d="M12 3v1" />
						<path d="M12 20v1" />
						<path d="M3 12h1" />
						<path d="M20 12h1" />
						<path d="m18.364 5.636-.707.707" />
						<path d="m6.343 17.657-.707.707" />
						<path d="m5.636 5.636.707.707" />
						<path d="m17.657 17.657.707.707" />
					</svg>
					<svg class="theme-icon theme-icon--moon" aria-hidden="true" viewBox="0 0 24 24">
						<path
							d="M21 12.79A9 9 0 0 1 11.21 3 7 7 0 1 0 21 12.79Z"
						/>
						<path
							d="M17.5 3.5 18 5l1.5.5L18 6 17.5 7.5 17 6l-1.5-.5L17 5z"
						/>
					</svg>
				</button>
		</nav>
	</div>
</header>

	<script type="module" is:inline>
		const btn = document.getElementById('theme-toggle');
		if (btn) {
			const getTheme = () =>
				document.documentElement.dataset.theme === 'dark' ? 'dark' : 'light';

			const setTheme = (theme) => {
				document.documentElement.dataset.theme = theme;
				try {
					localStorage.setItem('theme', theme);
				} catch (_) {
					// Ignore storage errors.
				}
			};

			btn.addEventListener('click', () => {
				const current = getTheme();
				setTheme(current === 'dark' ? 'light' : 'dark');
			});
		}
	</script>

<style>
	.site-header {
		position: fixed;
		top: 0;
		left: 0;
		right: 0;
		width: 100%;
		z-index: 50;
		background: var(--header-bg);
		backdrop-filter: blur(12px);
	}

	.inner {
		max-width: var(--page-max-width);
		margin: 0 auto;
		padding: 0.9rem var(--page-gutter);
		display: flex;
		align-items: center;
		justify-content: space-between;
	}

	.brand {
		text-decoration: none;
		color: inherit;
		font-weight: var(--font-weight-bold);
		letter-spacing: -0.03em;
		font-size: calc(var(--font-size-base) * 3);
	}

	.name {
		font-size: inherit;
	}

	.nav {
		display: flex;
		gap: 1rem;
		align-items: center;
		flex-wrap: wrap;
		justify-content: flex-end;
	}

	.nav a {
		position: relative;
		text-decoration: none;
		color: var(--text-muted);
		font-weight: var(--font-weight-base);
		font-size: calc(var(--font-size-base) * 1.25);
		padding: 0.35rem 0.55rem;
	}

	.nav a::after {
		content: '';
		position: absolute;
		left: 0.55rem;
		right: 0.55rem;
		bottom: 0.1rem;
		height: 2px;
		background: currentColor;
		transform: scaleX(0);
		transform-origin: center;
		transition: transform 180ms ease;
	}

	.nav a:hover {
		color: var(--text-strong);
	}

	.nav a:hover::after,
	.nav a.active::after {
		transform: scaleX(1);
	}

	.nav a.active {
		color: var(--text-strong);
		font-weight: var(--font-weight-bold);
	}

	.theme-toggle {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 2.75rem;
		height: 2.75rem;
		padding: 0;
		border-radius: 999px;
		border: 1px solid var(--border);
		background: var(--card-bg);
		color: var(--text-strong);
		cursor: pointer;
	}

	.theme-toggle:hover {
		background: rgba(17, 24, 39, 0.05);
	}

	.theme-icon {
		display: none;
		width: 18px;
		height: 18px;
		stroke: currentColor;
		fill: none;
		stroke-width: 2;
		stroke-linecap: round;
		stroke-linejoin: round;
	}

	/* When dark theme is active, show sun (meaning "switch to light"). */
	html[data-theme='dark'] .theme-icon--sun {
		display: inline-flex;
	}

	html[data-theme='dark'] .theme-icon--moon {
		display: none;
	}

	html[data-theme='light'] .theme-icon--moon {
		display: inline-flex;
	}

	html[data-theme='dark'] .theme-toggle {
		color: #ffffff;
		border-color: rgba(148, 163, 184, 0.6);
		background: rgba(15, 23, 42, 0.9);
	}

	@media (max-width: 520px) {
		.inner {
			gap: 0.75rem;
			align-items: flex-start;
		}

		.nav {
			width: 100%;
			justify-content: flex-start;
		}
	}
</style>
